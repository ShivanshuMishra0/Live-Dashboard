<script>
const STORAGE_KEY = 'atmosx_api_key';
let API_KEY = localStorage.getItem(STORAGE_KEY) || '';
let tempChart = null, aqiChart = null, compassChart = null;
let currentLat = null, currentLon = null;

const DAYS = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

const ICONS = {
  '01d':'☀️','01n':'🌙','02d':'⛅','02n':'⛅',
  '03d':'☁️','03n':'☁️','04d':'☁️','04n':'☁️',
  '09d':'🌧️','09n':'🌧️','10d':'🌦️','10n':'🌦️',
  '11d':'⛈️','11n':'⛈️','13d':'❄️','13n':'❄️','50d':'🌫️','50n':'🌫️'
};

const AQI_INFO = [null,
  {label:'Good', color:'#3dd68c', desc:'Air is clean and healthy'},
  {label:'Fair', color:'#a3e635', desc:'Acceptable quality'},
  {label:'Moderate', color:'#facc15', desc:'Some pollutants present'},
  {label:'Poor', color:'#f97316', desc:'Health effects possible'},
  {label:'Very Poor', color:'#ef4444', desc:'Health alert — limit outdoor activity'}
];

const UV_INFO = [
  {label:'Low', color:'#3dd68c'},
  {label:'Moderate', color:'#facc15'},
  {label:'High', color:'#f97316'},
  {label:'Very High', color:'#ef4444'},
  {label:'Extreme', color:'#a855f7'}
];

function uvInfo(uv) {
  if (uv <= 2) return UV_INFO[0];
  if (uv <= 5) return UV_INFO[1];
  if (uv <= 7) return UV_INFO[2];
  if (uv <= 10) return UV_INFO[3];
  return UV_INFO[4];
}

function windDir(deg) {
  const dirs = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];
  return dirs[Math.round(deg / 22.5) % 16];
}

function fmtTime(ts, tz) {
  const d = new Date((ts + tz) * 1000);
  let h = d.getUTCHours(), m = d.getUTCMinutes();
  const ampm = h >= 12 ? 'PM' : 'AM';
  h = h % 12 || 12;
  return `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')} ${ampm}`;
}

// Dew point formula
function dewPoint(temp, rh) {
  const a = 17.27, b = 237.7;
  const alpha = (a * temp) / (b + temp) + Math.log(rh / 100);
  return Math.round((b * alpha) / (a - alpha));
}

function setLoader(msg) {
  document.getElementById('loader-msg').textContent = msg;
  document.getElementById('loader').style.display = 'flex';
  document.getElementById('loader').classList.remove('fade');
}

function hideLoader() {
  const l = document.getElementById('loader');
  l.classList.add('fade');
  setTimeout(() => l.style.display = 'none', 700);
}

function showApiScreen() {
  document.getElementById('loader').style.display = 'none';
  document.getElementById('api-screen').style.display = 'flex';
}

function showApp() {
  document.getElementById('app').style.display = 'block';
}

function startWithKey() {
  const k = document.getElementById('api-input').value.trim();
  if (!k) return;
  API_KEY = k;
  localStorage.setItem(STORAGE_KEY, k);
  document.getElementById('api-screen').style.display = 'none';
  setLoader('Detecting location...');
  init();
}

async function fetchAll(lat, lon) {
  const [curr, fore, air, uv] = await Promise.all([
    fetch(`https://api.openweathermap.org/data/2.5/weather?lat=${lat}&lon=${lon}&appid=${API_KEY}&units=metric`).then(r=>r.json()),
    fetch(`https://api.openweathermap.org/data/2.5/forecast?lat=${lat}&lon=${lon}&appid=${API_KEY}&units=metric&cnt=56`).then(r=>r.json()),
    fetch(`https://api.openweathermap.org/data/2.5/air_pollution?lat=${lat}&lon=${lon}&appid=${API_KEY}`).then(r=>r.json()),
    fetch(`https://api.openweathermap.org/data/2.5/uvi?lat=${lat}&lon=${lon}&appid=${API_KEY}`).then(r=>r.json()).catch(()=>null)
  ]);
  if (curr.cod === 401) throw new Error('invalid_key');
  return { curr, fore, air, uv };
}

function renderHero(curr, dailyData) {
  const now = new Date();
  document.getElementById('h-city').textContent = curr.name;
  document.getElementById('h-date').textContent = `${DAYS[now.getDay()]}, ${now.getDate()} ${MONTHS[now.getMonth()]} ${now.getFullYear()} · ${now.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}`;
  document.getElementById('h-icon').textContent = ICONS[curr.weather[0].icon] || '🌤️';
  document.getElementById('h-temp').textContent = Math.round(curr.main.temp);
  document.getElementById('h-cond').textContent = curr.weather[0].description.replace(/\b\w/g, l=>l.toUpperCase());
  document.getElementById('h-max').textContent = `↑ ${Math.round(curr.main.temp_max)}°`;
  document.getElementById('h-min').textContent = `↓ ${Math.round(curr.main.temp_min)}°`;
  document.getElementById('h-feels').textContent = `${Math.round(curr.main.feels_like)}°C`;
  document.getElementById('h-dew').textContent = `${dewPoint(curr.main.temp, curr.main.humidity)}°C`;
  document.getElementById('h-cloud').textContent = `${curr.clouds.all}%`;
  document.getElementById('h-hum').textContent = `${curr.main.humidity}%`;

  // Sync time
  document.getElementById('sync-time').textContent = `Updated ${now.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}`;
}

function renderStats(curr, uvData) {
  document.getElementById('s-hum').textContent = curr.main.humidity;
  const windKph = Math.round(curr.wind.speed * 3.6);
  document.getElementById('s-wind').textContent = windKph;
  document.getElementById('s-vis').textContent = Math.round((curr.visibility || 0) / 1000);
  document.getElementById('s-press').textContent = curr.main.pressure;
  document.getElementById('s-precip').textContent = curr.rain ? (curr.rain['1h'] || 0).toFixed(2) : '0.00';

  // UV Index
  let uvVal = uvData && uvData.value != null ? Math.round(uvData.value) : null;
  if (uvVal !== null) {
    const info = uvInfo(uvVal);
    document.getElementById('s-uv').textContent = uvVal;
    document.getElementById('s-uv-label').textContent = info.label;
    const fill = document.getElementById('uv-fill');
    fill.style.width = Math.min(uvVal / 12 * 100, 100) + '%';
    fill.style.background = info.color;
  } else {
    document.getElementById('s-uv').textContent = 'N/A';
    document.getElementById('s-uv-label').textContent = '';
  }

  // Wind card
  document.getElementById('w-speed').textContent = windKph;
  document.getElementById('w-dir').textContent = windDir(curr.wind.deg || 0);
  document.getElementById('w-gust').textContent = curr.wind.gust ? Math.round(curr.wind.gust * 3.6) + ' kph' : '-- kph';
  document.getElementById('w-sea').textContent = (curr.main.sea_level || curr.main.pressure) + ' mb';
  document.getElementById('w-grnd').textContent = (curr.main.grnd_level || curr.main.pressure) + ' mb';
  document.getElementById('w-tmin').textContent = Math.round(curr.main.temp_min) + '°C';
  document.getElementById('w-tmax').textContent = Math.round(curr.main.temp_max) + '°C';

  drawCompass(curr.wind.deg || 0);
}

function renderSun(curr) {
  const tz = curr.timezone;
  const rise = fmtTime(curr.sys.sunrise, tz);
  const set = fmtTime(curr.sys.sunset, tz);
  document.getElementById('sun-rise').textContent = rise;
  document.getElementById('sun-set').textContent = set;

  const now = Math.floor(Date.now() / 1000);
  const r = curr.sys.sunrise, s = curr.sys.sunset;
  const pct = Math.max(0, Math.min(100, ((now - r) / (s - r)) * 100));
  document.getElementById('sun-prog').style.width = pct + '%';

  const durSec = s - r;
  const dh = Math.floor(durSec / 3600), dm = Math.floor((durSec % 3600) / 60);
  document.getElementById('day-len').textContent = `${dh}h ${dm}m`;

  drawSunArc(pct / 100);
}

function drawSunArc(progress) {
  const canvas = document.getElementById('sunArc');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);

  const cx = W / 2, cy = H - 10, r = H - 20;

  // Track arc
  ctx.beginPath();
  ctx.arc(cx, cy, r, Math.PI, 0);
  ctx.strokeStyle = 'rgba(255,255,255,0.06)';
  ctx.lineWidth = 3;
  ctx.stroke();

  // Progress arc
  const startAngle = Math.PI;
  const endAngle = Math.PI + progress * Math.PI;
  ctx.beginPath();
  ctx.arc(cx, cy, r, startAngle, endAngle);
  ctx.strokeStyle = '#f5a623';
  ctx.lineWidth = 3;
  ctx.stroke();

  // Sun position
  const angle = Math.PI + progress * Math.PI;
  const sx = cx + r * Math.cos(angle);
  const sy = cy + r * Math.sin(angle);
  ctx.beginPath();
  ctx.arc(sx, sy, 8, 0, Math.PI * 2);
  ctx.fillStyle = '#f5a623';
  ctx.fill();
  ctx.shadowColor = '#f5a623';
  ctx.shadowBlur = 12;
  ctx.fill();
  ctx.shadowBlur = 0;
}

function drawCompass(deg) {
  const canvas = document.getElementById('compassCanvas');
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);
  const cx = W / 2, cy = H / 2, r = W / 2 - 8;

  // Outer ring
  ctx.beginPath();
  ctx.arc(cx, cy, r, 0, Math.PI * 2);
  ctx.strokeStyle = 'rgba(255,255,255,0.08)';
  ctx.lineWidth = 2;
  ctx.stroke();

  // Tick marks
  for (let i = 0; i < 36; i++) {
    const a = (i * 10 * Math.PI) / 180;
    const inner = i % 9 === 0 ? r - 14 : r - 8;
    ctx.beginPath();
    ctx.moveTo(cx + inner * Math.sin(a), cy - inner * Math.cos(a));
    ctx.lineTo(cx + r * Math.sin(a), cy - r * Math.cos(a));
    ctx.strokeStyle = i % 9 === 0 ? 'rgba(255,255,255,0.3)' : 'rgba(255,255,255,0.1)';
    ctx.lineWidth = i % 9 === 0 ? 2 : 1;
    ctx.stroke();
  }

  // N label
  ctx.fillStyle = '#f75f5f';
  ctx.font = '700 11px Syne, sans-serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillText('N', cx, cy - r + 20);

  // Arrow
  const a = (deg * Math.PI) / 180;
  const arrowLen = r - 22;

  ctx.beginPath();
  ctx.moveTo(cx + arrowLen * Math.sin(a), cy - arrowLen * Math.cos(a));
  ctx.lineTo(cx - 14 * Math.sin(a), cy + 14 * Math.cos(a));
  ctx.strokeStyle = '#4f8ef7';
  ctx.lineWidth = 2.5;
  ctx.lineCap = 'round';
  ctx.stroke();

  ctx.beginPath();
  ctx.arc(cx, cy, 4, 0, Math.PI * 2);
  ctx.fillStyle = '#4f8ef7';
  ctx.fill();
}

function renderForecast(fore) {
  const dailyMap = {};
  fore.list.forEach(item => {
    const d = new Date(item.dt * 1000);
    const key = `${d.getFullYear()}-${d.getMonth()}-${d.getDate()}`;
    if (!dailyMap[key]) dailyMap[key] = {
      maxTemp: -999, minTemp: 999,
      icons: [], pop: [],
      day: DAYS[d.getDay()],
      dt: item.dt
    };
    dailyMap[key].maxTemp = Math.max(dailyMap[key].maxTemp, item.main.temp_max);
    dailyMap[key].minTemp = Math.min(dailyMap[key].minTemp, item.main.temp_min);
    dailyMap[key].icons.push(item.weather[0].icon);
    dailyMap[key].pop.push(item.pop || 0);
  });

  const days = Object.values(dailyMap).slice(0, 7);
  const todayKey = Object.keys(dailyMap)[0];

  // Forecast cards
  const scroll = document.getElementById('forecast-scroll');
  scroll.innerHTML = days.map((d, i) => {
    const icon = d.icons[Math.floor(d.icons.length / 2)] || d.icons[0];
    const pop = Math.round(Math.max(...d.pop) * 100);
    return `<div class="forecast-day-card ${i === 0 ? 'today' : ''}">
      <div class="fd-name">${i === 0 ? 'Today' : d.day}</div>
      <div class="fd-icon">${ICONS[icon] || '🌤️'}</div>
      <div class="fd-max">${Math.round(d.maxTemp)}°</div>
      <div class="fd-min">${Math.round(d.minTemp)}°</div>
      <div class="fd-pop">💧 ${pop}%</div>
    </div>`;
  }).join('');

  // Temp chart
  const ctx = document.getElementById('tempChart').getContext('2d');
  if (tempChart) tempChart.destroy();
  tempChart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: days.map((d, i) => i === 0 ? 'Today' : d.day),
      datasets: [
        {
          label: 'Max °C',
          data: days.map(d => Math.round(d.maxTemp)),
          borderColor: '#f5a623',
          backgroundColor: 'rgba(245,166,35,0.07)',
          borderWidth: 2.5,
          pointBackgroundColor: '#f5a623',
          pointRadius: 5,
          pointHoverRadius: 7,
          tension: 0.4,
          fill: false
        },
        {
          label: 'Min °C',
          data: days.map(d => Math.round(d.minTemp)),
          borderColor: '#4f8ef7',
          backgroundColor: 'rgba(79,142,247,0.07)',
          borderWidth: 2.5,
          pointBackgroundColor: '#4f8ef7',
          pointRadius: 5,
          pointHoverRadius: 7,
          tension: 0.4,
          fill: false
        }
      ]
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: {
          display: true,
          labels: { color: '#6b7194', font: { size: 11 }, boxWidth: 12, padding: 16 }
        },
        tooltip: {
          backgroundColor: '#121520',
          borderColor: 'rgba(255,255,255,0.1)',
          borderWidth: 1,
          titleColor: '#eef0f8',
          bodyColor: '#6b7194',
          padding: 12,
          callbacks: { label: ctx => `${ctx.dataset.label}: ${ctx.raw}°C` }
        }
      },
      scales: {
        x: {
          grid: { color: 'rgba(255,255,255,0.03)' },
          ticks: { color: '#6b7194', font: { size: 11 } }
        },
        y: {
          grid: { color: 'rgba(255,255,255,0.03)' },
          ticks: { color: '#6b7194', font: { size: 11 }, callback: v => v + '°' }
        }
      }
    }
  });

  // Rain bars
  const rainHtml = days.map(d => {
    const pop = Math.round(Math.max(...d.pop) * 100);
    return `<div class="rain-row">
      <div class="rain-day-name">${d.day}</div>
      <div class="rain-track"><div class="rain-fill" style="width:${pop}%"></div></div>
      <div class="rain-pct">${pop}%</div>
    </div>`;
  }).join('');
  document.getElementById('rain-rows').innerHTML = rainHtml;

  return days;
}

function renderAQI(air) {
  const aqi = air.list[0].main.aqi;
  const c = air.list[0].components;
  const info = AQI_INFO[aqi];

  document.getElementById('aqi-label').textContent = info.label;
  document.getElementById('aqi-label').style.color = info.color;
  document.getElementById('aqi-num').textContent = Math.round(c.pm2_5);
  document.getElementById('aqi-desc').textContent = info.desc;

  document.getElementById('p-pm10').textContent = Math.round(c.pm10);
  document.getElementById('p-o3').textContent = Math.round(c.o3);
  document.getElementById('p-so2').textContent = Math.round(c.so2);
  document.getElementById('p-pm25').textContent = Math.round(c.pm2_5);
  document.getElementById('p-co').textContent = Math.round(c.co);
  document.getElementById('p-no2').textContent = Math.round(c.no2);

  // Gauge
  const canvas = document.getElementById('aqiCanvas');
  const ctx = canvas.getContext('2d');
  if (aqiChart) aqiChart.destroy();

  const pct = (aqi - 1) / 4;
  aqiChart = new Chart(ctx, {
    type: 'doughnut',
    data: {
      datasets: [{
        data: [pct, 1 - pct],
        backgroundColor: [info.color, '#121520'],
        borderWidth: 0,
        circumference: 260,
        rotation: 230
      }]
    },
    options: {
      cutout: '70%',
      plugins: { legend: { display: false }, tooltip: { enabled: false } },
      animation: { duration: 1000, easing: 'easeInOutQuart' }
    }
  });
}

function renderCitySwitcher(lat, lon, cityName) {
  const defaults = [
    { name: cityName, lat, lon },
    { name: 'Mumbai', lat: 19.08, lon: 72.88 },
    { name: 'Bangalore', lat: 12.97, lon: 77.59 },
  ];

  const sw = document.getElementById('city-switcher');
  sw.innerHTML = '';

  defaults.forEach((city, i) => {
    const btn = document.createElement('div');
    btn.className = 'city-btn' + (i === 0 ? ' active' : '');
    btn.innerHTML = `<span class="city-btn-name">${city.name}</span><span class="city-btn-temp" id="ctab-${i}">--°C</span>`;
    btn.onclick = () => {
      document.querySelectorAll('.city-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      loadCity(city.lat, city.lon);
    };
    sw.appendChild(btn);

    fetch(`https://api.openweathermap.org/data/2.5/weather?lat=${city.lat}&lon=${city.lon}&appid=${API_KEY}&units=metric`)
      .then(r => r.json())
      .then(d => {
        const el = document.getElementById(`ctab-${i}`);
        if (el) el.textContent = Math.round(d.main.temp) + '°C';
      }).catch(() => {});
  });
}

async function loadCity(lat, lon) {
  try {
    const { curr, fore, air, uv } = await fetchAll(lat, lon);
    renderHero(curr, null);
    renderStats(curr, uv);
    renderSun(curr);
    renderForecast(fore);
    renderAQI(air);
  } catch(e) { console.error(e); }
}

async function init() {
  if (!API_KEY) { showApiScreen(); return; }
  showApp();
  setLoader('Detecting your location...');

  const go = async (lat, lon) => {
    currentLat = lat; currentLon = lon;
    try {
      setLoader('Fetching live weather...');
      const { curr, fore, air, uv } = await fetchAll(lat, lon);
      if (curr.cod === 401 || (air && air.cod === 401)) throw new Error('invalid_key');
      renderHero(curr, null);
      renderStats(curr, uv);
      renderSun(curr);
      renderForecast(fore);
      renderAQI(air);
      renderCitySwitcher(lat, lon, curr.name);
      hideLoader();

      // Auto-refresh every 10 min
      setInterval(async () => {
        try {
          const { curr, fore, air, uv } = await fetchAll(currentLat, currentLon);
          renderHero(curr, null);
          renderStats(curr, uv);
          renderSun(curr);
          renderForecast(fore);
          renderAQI(air);
        } catch(e) {}
      }, 600000);

    } catch(e) {
      if (e.message === 'invalid_key') {
        localStorage.removeItem(STORAGE_KEY);
        document.getElementById('app').style.display = 'none';
        showApiScreen();
        hideLoader();
      }
    }
  };

  navigator.geolocation.getCurrentPosition(
    pos => go(pos.coords.latitude, pos.coords.longitude),
    () => go(28.6139, 77.2090) // Default: New Delhi
  );
}

window.onload = () => init();
</script>
