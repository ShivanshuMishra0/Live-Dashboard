<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AtmosX — Live Weather</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #07080d;
  --bg2: #0d0f18;
  --bg3: #121520;
  --bg4: #181c2a;
  --border: rgba(255,255,255,0.06);
  --border2: rgba(255,255,255,0.12);
  --text: #eef0f8;
  --muted: #6b7194;
  --accent: #4f8ef7;
  --accent2: #7c6af7;
  --green: #3dd68c;
  --amber: #f5a623;
  --red: #f75f5f;
  --teal: #2dcfcf;
  --font-display: 'Syne', sans-serif;
  --font-mono: 'DM Mono', monospace;
  --font-body: 'DM Sans', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font-body);
  min-height: 100vh;
  overflow-x: hidden;
}

/* Animated background */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 40% at 15% 20%, rgba(79,142,247,0.07) 0%, transparent 60%),
    radial-gradient(ellipse 50% 50% at 85% 80%, rgba(124,106,247,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 40% 30% at 50% 50%, rgba(45,207,207,0.03) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* LOADING */
#loader {
  position: fixed; inset: 0;
  background: var(--bg);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 20px; z-index: 1000;
  transition: opacity 0.6s ease;
}

#loader.fade { opacity: 0; pointer-events: none; }

.loader-orb {
  width: 56px; height: 56px;
  border-radius: 50%;
  border: 2px solid rgba(79,142,247,0.15);
  border-top-color: var(--accent);
  border-right-color: var(--accent2);
  animation: spin 1s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loader-text {
  font-family: var(--font-display);
  font-size: 13px;
  color: var(--muted);
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.loader-brand {
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 800;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: -0.02em;
}

/* API KEY SCREEN */
#api-screen {
  display: none;
  position: fixed; inset: 0;
  background: var(--bg);
  align-items: center; justify-content: center;
  z-index: 999;
}

.api-box {
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-radius: 24px;
  padding: 40px;
  max-width: 460px;
  width: 90%;
  text-align: center;
}

.api-box h1 {
  font-family: var(--font-display);
  font-size: 26px;
  font-weight: 800;
  background: linear-gradient(135deg, var(--accent), var(--teal));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 8px;
}

.api-box p {
  color: var(--muted);
  font-size: 14px;
  line-height: 1.7;
  margin-bottom: 24px;
}

.api-box p a { color: var(--accent); text-decoration: none; }

.api-input {
  width: 100%;
  background: var(--bg4);
  border: 1px solid var(--border2);
  border-radius: 12px;
  padding: 14px 16px;
  color: var(--text);
  font-family: var(--font-mono);
  font-size: 13px;
  outline: none;
  margin-bottom: 12px;
  transition: border-color 0.2s;
}

.api-input:focus { border-color: var(--accent); }

.api-btn {
  width: 100%;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  border: none; border-radius: 12px;
  padding: 14px;
  color: #fff;
  font-family: var(--font-display);
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  transition: opacity 0.2s, transform 0.15s;
}

.api-btn:hover { opacity: 0.9; transform: translateY(-1px); }
.api-btn:active { transform: scale(0.98); }

/* MAIN LAYOUT */
#app {
  display: none;
  position: relative;
  z-index: 1;
  padding: 20px;
  max-width: 1440px;
  margin: 0 auto;
}

/* TOP HEADER BAR */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
  padding: 0 4px;
}

.brand {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 800;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.topbar-right {
  display: flex; align-items: center; gap: 16px;
}

.live-badge {
  display: flex; align-items: center; gap: 6px;
  background: rgba(61,214,140,0.1);
  border: 1px solid rgba(61,214,140,0.2);
  padding: 6px 12px; border-radius: 20px;
  font-size: 12px; color: var(--green);
  font-family: var(--font-mono);
}

.live-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--green);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

.last-sync {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--muted);
}

/* GRID LAYOUT */
.grid-main {
  display: grid;
  grid-template-columns: 320px 1fr 1fr 260px;
  grid-template-rows: auto auto auto;
  gap: 14px;
}

/* GLASS CARD */
.card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 20px;
  position: relative;
  overflow: hidden;
  transition: border-color 0.3s;
  animation: fadeUp 0.5s ease both;
}

.card:hover { border-color: var(--border2); }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Staggered animation delays */
.card:nth-child(1) { animation-delay: 0.05s; }
.card:nth-child(2) { animation-delay: 0.1s; }
.card:nth-child(3) { animation-delay: 0.15s; }
.card:nth-child(4) { animation-delay: 0.2s; }
.card:nth-child(5) { animation-delay: 0.25s; }
.card:nth-child(6) { animation-delay: 0.3s; }
.card:nth-child(7) { animation-delay: 0.35s; }
.card:nth-child(8) { animation-delay: 0.4s; }

.card-label {
  font-family: var(--font-display);
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--muted);
  margin-bottom: 14px;
}

/* ═══════════════════════════
   HERO CARD — col 1, rows 1-2
════════════════════════════ */
.hero-card {
  grid-column: 1;
  grid-row: 1 / 3;
  background: linear-gradient(160deg, #0e2a6e 0%, #0a1a4a 35%, #060d2b 100%);
  border-color: rgba(79,142,247,0.2);
  padding: 24px;
  display: flex;
  flex-direction: column;
}

.hero-card::before {
  content: '';
  position: absolute;
  top: -60px; right: -60px;
  width: 240px; height: 240px;
  background: radial-gradient(circle, rgba(79,142,247,0.15) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.hero-card::after {
  content: '';
  position: absolute;
  bottom: -40px; left: -40px;
  width: 180px; height: 180px;
  background: radial-gradient(circle, rgba(124,106,247,0.1) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.hero-location {
  display: flex; align-items: center; gap: 6px;
  font-family: var(--font-display);
  font-size: 16px; font-weight: 700;
  color: #fff;
  margin-bottom: 4px;
}

.hero-location .pin { font-size: 14px; }

.hero-date {
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  margin-bottom: 20px;
  font-family: var(--font-mono);
}

.hero-weather-icon {
  font-size: 80px;
  display: block;
  margin: 8px 0;
  filter: drop-shadow(0 8px 24px rgba(0,0,0,0.4));
  line-height: 1;
}

.hero-temp-row {
  display: flex; align-items: flex-start; gap: 8px;
  margin: 12px 0 4px;
}

.hero-temp {
  font-family: var(--font-display);
  font-size: 72px;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  letter-spacing: -0.04em;
}

.hero-temp-unit {
  font-size: 28px;
  font-weight: 400;
  color: rgba(255,255,255,0.6);
  margin-top: 10px;
}

.hero-condition {
  font-size: 15px;
  color: rgba(255,255,255,0.75);
  margin-bottom: 4px;
  font-weight: 500;
}

.hero-minmax {
  display: flex; gap: 12px;
  font-family: var(--font-mono);
  font-size: 13px;
  margin-bottom: 20px;
}

.hero-max { color: #f5a623; }
.hero-min { color: #4f8ef7; }

.hero-divider {
  height: 1px;
  background: rgba(255,255,255,0.08);
  margin: 16px 0;
}

/* Feels like / dew point inside hero */
.hero-extra {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 10px; margin-bottom: 16px;
}

.hero-extra-item {
  background: rgba(255,255,255,0.06);
  border-radius: 12px; padding: 10px 12px;
}

.hero-extra-label {
  font-size: 10px; color: rgba(255,255,255,0.45);
  text-transform: uppercase; letter-spacing: 0.08em;
  margin-bottom: 4px;
}

.hero-extra-val {
  font-family: var(--font-mono);
  font-size: 17px; font-weight: 500;
  color: #fff;
}

/* City switcher */
.city-switcher {
  display: flex; flex-direction: column; gap: 6px;
  margin-top: auto;
}

.city-switcher-label {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.35);
  margin-bottom: 4px;
}

.city-btn {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px;
  padding: 10px 14px;
  cursor: pointer;
  transition: all 0.2s;
  display: flex; justify-content: space-between; align-items: center;
}

.city-btn:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.16); }
.city-btn.active { background: rgba(79,142,247,0.2); border-color: rgba(79,142,247,0.4); }

.city-btn-name { font-size: 13px; font-weight: 600; color: #fff; }
.city-btn-temp { font-family: var(--font-mono); font-size: 13px; color: rgba(255,255,255,0.65); }

/* ═══════════════════════════
   7-DAY FORECAST — col 2-3, row 1
════════════════════════════ */
.forecast-card {
  grid-column: 2 / 4;
  grid-row: 1;
  padding: 20px;
}

.forecast-scroll {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8px;
}

.forecast-day-card {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 12px 8px;
  display: flex; flex-direction: column;
  align-items: center; gap: 6px;
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}

.forecast-day-card::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(79,142,247,0.08), transparent);
  opacity: 0;
  transition: opacity 0.2s;
}

.forecast-day-card:hover { border-color: rgba(79,142,247,0.3); transform: translateY(-2px); }
.forecast-day-card:hover::before { opacity: 1; }
.forecast-day-card.today { border-color: rgba(79,142,247,0.4); background: rgba(79,142,247,0.08); }

.fd-name { font-size: 11px; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
.fd-icon { font-size: 26px; }
.fd-max { font-family: var(--font-mono); font-size: 14px; font-weight: 500; color: var(--amber); }
.fd-min { font-family: var(--font-mono); font-size: 12px; color: var(--accent); }
.fd-pop {
  font-size: 10px; color: var(--teal);
  display: flex; align-items: center; gap: 3px;
}

/* ═══════════════════════════
   TEMP CHART — col 2-3, row 2
════════════════════════════ */
.chart-card {
  grid-column: 2 / 4;
  grid-row: 2;
}

/* ═══════════════════════════
   SUN CARD — col 4, row 1
════════════════════════════ */
.sun-card {
  grid-column: 4;
  grid-row: 1;
}

.sun-arc-wrap {
  position: relative;
  height: 110px;
  margin-bottom: 12px;
}

.sun-times {
  display: flex; justify-content: space-between;
  margin-top: 8px;
}

.sun-time-item { text-align: center; }
.sun-time-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
.sun-time-val { font-family: var(--font-mono); font-size: 17px; font-weight: 500; color: var(--text); }

.sun-progress-bar {
  height: 4px;
  background: var(--bg4);
  border-radius: 2px;
  margin-top: 16px;
  overflow: hidden;
}

.sun-progress-fill {
  height: 100%;
  border-radius: 2px;
  background: linear-gradient(90deg, var(--amber), #f7d05f);
  transition: width 1s ease;
}

.day-length {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 10px;
}

.day-length-label { font-size: 11px; color: var(--muted); }
.day-length-val { font-family: var(--font-mono); font-size: 12px; color: var(--amber); }

/* ═══════════════════════════
   STATS — col 1, row 3
════════════════════════════ */
.stats-card {
  grid-column: 1;
  grid-row: 3;
}

.stats-grid-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.stat-item {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 14px;
  position: relative;
  overflow: hidden;
  transition: all 0.2s;
}

.stat-item:hover { border-color: var(--border2); transform: translateY(-1px); }

.stat-item::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 2px;
  border-radius: 0 0 14px 14px;
}

.stat-item.blue::after { background: linear-gradient(90deg, var(--accent), transparent); }
.stat-item.green::after { background: linear-gradient(90deg, var(--green), transparent); }
.stat-item.amber::after { background: linear-gradient(90deg, var(--amber), transparent); }
.stat-item.teal::after { background: linear-gradient(90deg, var(--teal), transparent); }
.stat-item.red::after { background: linear-gradient(90deg, var(--red), transparent); }
.stat-item.purple::after { background: linear-gradient(90deg, var(--accent2), transparent); }

.stat-header { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; }
.stat-icon { font-size: 14px; }
.stat-label-text { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.07em; font-weight: 600; }
.stat-val { font-family: var(--font-mono); font-size: 22px; font-weight: 500; color: var(--text); }
.stat-unit-text { font-size: 12px; color: var(--muted); margin-left: 2px; }

/* UV Bar */
.uv-bar { height: 4px; background: var(--bg4); border-radius: 2px; margin-top: 6px; overflow: hidden; }
.uv-fill { height: 100%; border-radius: 2px; transition: width 1s ease; }

/* ═══════════════════════════
   AQI — col 2, row 3
════════════════════════════ */
.aqi-card {
  grid-column: 2;
  grid-row: 3;
}

.aqi-layout {
  display: flex; gap: 16px; align-items: flex-start; height: calc(100% - 36px);
}

.aqi-gauge-wrap {
  position: relative;
  width: 130px; height: 130px;
  flex-shrink: 0;
}

.aqi-center-info {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  text-align: center; width: 80px;
}

.aqi-center-label { font-size: 11px; font-weight: 700; font-family: var(--font-display); }
.aqi-center-num { font-family: var(--font-mono); font-size: 26px; font-weight: 500; color: var(--text); }
.aqi-center-sub { font-size: 9px; color: var(--muted); margin-top: 2px; }

.aqi-desc-text { font-size: 11px; color: var(--muted); margin-top: 8px; text-align: center; }

.pollutants-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
  flex: 1;
}

.poll-item {
  background: var(--bg3);
  border-radius: 12px; padding: 10px 12px;
  border: 1px solid var(--border);
}

.poll-top { display: flex; align-items: center; gap: 5px; margin-bottom: 4px; }
.poll-dot { width: 7px; height: 7px; border-radius: 50%; }
.poll-name-text { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
.poll-val-text { font-family: var(--font-mono); font-size: 18px; font-weight: 500; color: var(--text); }
.poll-unit { font-size: 10px; color: var(--muted); margin-left: 2px; }

/* ═══════════════════════════
   RAIN — col 3, row 3
════════════════════════════ */
.rain-card {
  grid-column: 3;
  grid-row: 3;
}

.rain-row {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 11px;
}

.rain-day-name { font-size: 12px; color: var(--muted); width: 62px; flex-shrink: 0; font-family: var(--font-mono); }
.rain-track { flex: 1; height: 6px; background: var(--bg4); border-radius: 3px; overflow: hidden; }
.rain-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--accent), var(--teal)); transition: width 1s ease; }
.rain-pct { font-family: var(--font-mono); font-size: 11px; color: var(--accent); width: 32px; text-align: right; }

/* ═══════════════════════════
   WIND / EXTRAS — col 4, rows 2-3
════════════════════════════ */
.wind-card {
  grid-column: 4;
  grid-row: 2 / 4;
  display: flex; flex-direction: column; gap: 14px;
}

.wind-compass-wrap {
  position: relative;
  width: 120px; height: 120px;
  margin: 0 auto;
}

.wind-compass-wrap canvas { position: absolute; top: 0; left: 0; }

.wind-compass-center {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.wind-speed-big { font-family: var(--font-mono); font-size: 20px; font-weight: 500; color: var(--text); }
.wind-unit-small { font-size: 10px; color: var(--muted); }

.wind-dir-badge {
  display: inline-block;
  background: rgba(79,142,247,0.15);
  border: 1px solid rgba(79,142,247,0.25);
  border-radius: 20px;
  padding: 3px 10px;
  font-size: 11px;
  color: var(--accent);
  font-family: var(--font-mono);
  margin: 6px auto 0;
  display: block;
  text-align: center;
  width: fit-content;
}

.extra-stats { display: flex; flex-direction: column; gap: 10px; }

.extra-stat-row {
  display: flex; justify-content: space-between; align-items: center;
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 12px; padding: 12px 14px;
}

.extra-stat-left { display: flex; align-items: center; gap: 8px; }
.extra-stat-icon { font-size: 16px; }
.extra-stat-label { font-size: 12px; color: var(--muted); }
.extra-stat-val { font-family: var(--font-mono); font-size: 15px; font-weight: 500; color: var(--text); }

/* RESPONSIVE */
@media (max-width: 1200px) {
  .grid-main { grid-template-columns: 300px 1fr 240px; }
  .forecast-card { grid-column: 2 / 4; }
  .chart-card { grid-column: 2 / 4; }
  .aqi-card { grid-column: 2; }
  .rain-card { grid-column: 3; }
  .wind-card { grid-column: 3; grid-row: 3; }
  .stats-card { grid-column: 2; grid-row: 4; }
  .aqi-card { grid-row: 4; }
}

@media (max-width: 900px) {
  .grid-main { grid-template-columns: 1fr 1fr; }
  .hero-card { grid-column: 1 / 3; grid-row: 1; }
  .forecast-card { grid-column: 1 / 3; grid-row: 2; }
  .chart-card { grid-column: 1 / 3; grid-row: 3; }
  .sun-card { grid-column: 1; grid-row: 4; }
  .wind-card { grid-column: 2; grid-row: 4; }
  .stats-card { grid-column: 1 / 3; grid-row: 5; }
  .aqi-card { grid-column: 1; grid-row: 6; }
  .rain-card { grid-column: 2; grid-row: 6; }
}

@media (max-width: 600px) {
  #app { padding: 12px; }
  .grid-main { grid-template-columns: 1fr; gap: 10px; }
  .hero-card, .forecast-card, .chart-card, .sun-card, .wind-card, .stats-card, .aqi-card, .rain-card {
    grid-column: 1; grid-row: auto;
  }
  .forecast-scroll { grid-template-columns: repeat(4, 1fr); }
}
</style>
</head>
<body>

<!-- LOADER -->
<div id="loader">
  <div class="loader-brand">AtmosX</div>
  <div class="loader-orb"></div>
